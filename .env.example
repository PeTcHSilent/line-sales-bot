# LINE Messaging API (Sales Bot OA)
LINE_CHANNEL_SECRET=your_sales_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_sales_line_channel_access_token

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# PostgreSQL (Railway)
DATABASE_URL=postgresql://user:password@host:5432/salesbot

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
JWT_SECRET=your_jwt_secret_min_32_chars

# Server
PORT=3001
NODE_ENV=production

# Facebook Messenger (ไม่บังคับ — ถ้าไม่ใส่ Messenger จะถูกปิด)
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FB_VERIFY_TOKEN=torkun_verify_token
